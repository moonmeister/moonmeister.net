---
import { getEmDashCollection, getTerm } from 'emdash';
import ArchivePage from '../../components/ArchivePage.astro';

const { slug } = Astro.params;
const tagSlug = slug!;

const term = await getTerm('tag', tagSlug);

if (!term) {
	return Astro.redirect('/404');
}

const { entries: filteredPosts, cacheHint } = await getEmDashCollection(
	'posts',
	{
		status: 'published',
		where: { tag: tagSlug },
		orderBy: { published_at: 'desc' },
	}
);

Astro.cache.set(cacheHint);

const pageTitle = term.label;
---

<ArchivePage {pageTitle} posts={filteredPosts} />
