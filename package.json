{
  "name": "moonmeister-site",
  "private": true,
  "type": "module",
  "imports": {
    "#styles": "./src/styles/global.css"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy",
    "admin": "open 'http://localhost:4321/_emdash/api/setup/dev-bypass?redirect=/_emdash/admin'",
    "db:wipe": "rm -rf .wrangler/state/v3/d1 node_modules/.vite",
    "astro": "astro",
    "format": "prettier --write . --plugin-search-dir=.",
    "check:format": "prettier --check . --plugin-search-dir=.",
    "check:spell": "cspell \"./src/**/*.{astro,ts,md,css}\"",
    "check:types": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "1.10.9",
    "@emdash-cms/cloudflare": "^0.20.0",
    "@moonmeister/plugin-asides": "workspace:*",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "astro-feather": "^1.0.0",
    "emdash": "^0.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "cspell": "^9.8.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.105.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
