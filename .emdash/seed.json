{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "settings": {
    "title": "Stevie Wonder",
    "tagline": "Notes on software, systems, and building on the web.",
    "social": {
      "github": "moonmeister",
      "linkedin": "aj-moon",
      "twitter": "moon_meister"
    }
  },
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "supports": [
        "drafts",
        "revisions",
        "search",
        "preview"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "unique": false
        },
        {
          "slug": "body",
          "label": "Content",
          "type": "portableText",
          "required": false,
          "unique": false
        }
      ]
    },
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "supports": [
        "drafts",
        "revisions",
        "preview"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "unique": false
        },
        {
          "slug": "body",
          "label": "Content",
          "type": "portableText",
          "required": false,
          "unique": false
        },
        {
          "slug": "hero_image",
          "label": "Hero Image",
          "type": "image",
          "required": false,
          "unique": false
        }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "tag",
      "label": "Tags",
      "labelSingular": "Tag",
      "hierarchical": false,
      "collections": [
        "posts"
      ],
      "terms": [
        {
          "slug": "seeded",
          "label": "Seeded"
        }
      ]
    }
  ],
  "menus": [
    {
      "name": "primary",
      "label": "Primary Navigation",
      "items": [
        {
          "type": "custom",
          "label": "Home",
          "url": "/"
        },
        {
          "type": "custom",
          "label": "Blog",
          "url": "/blog"
        }
      ]
    }
  ],
  "content": {
    "pages": [
      {
        "id": "page-home",
        "slug": "home",
        "status": "published",
        "data": {
          "title": "Welcome",
          "hero_image": {
            "$media": {
              "url": "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1200&h=1200&fit=crop",
              "alt": "A laptop, notebook, and coffee on a desk",
              "filename": "home-hero.jpg"
            }
          },
          "body": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Welcome to your new site. This homepage is managed in EmDash so you can update it without changing code."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Use this space to introduce the site, explain what readers will find here, and point them toward the most important content."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "You can replace this seeded copy and image from the EmDash admin once the site is initialized."
                }
              ]
            }
          ]
        }
      }
    ],
    "posts": [
      {
        "id": "post-hello-world",
        "slug": "hello-world",
        "status": "published",
        "data": {
          "title": "Hello World",
          "body": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Welcome to the blog. This is your default seeded post."
                }
              ]
            }
          ]
        },
        "taxonomies": {
          "tag": [
            "seeded"
          ]
        }
      },
      {
        "id": "post-sorting-check",
        "slug": "sorting-check",
        "status": "published",
        "data": {
          "title": "Sorting Check",
          "body": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "This second seeded post exists to validate published-date ordering in blog and tag archives."
                }
              ]
            }
          ]
        },
        "taxonomies": {
          "tag": [
            "seeded"
          ]
        }
      }
    ]
  }
}