# EmDash email sender configuration for cloudflareEmail()
# Required to enable EmDash email sending in astro.config.js
EMDASH_EMAIL_FROM=cms@cms.moonmeister.net

# Optional display name for sender
EMDASH_EMAIL_FROM_NAME="Moonmeister CMS"

# Optional reply-to override
EMDASH_EMAIL_REPLY_TO=admin@moonmeister.net
