---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseHead from '../components/BaseHead.astro';
import Tags from '../components/Tags.astro';
import FormattedDate from '../components/FormattedDate.astro';

import { SITE_DESCRIPTION } from '../consts';

import type { ContentEntry } from 'emdash';
import type { Post } from '../../emdash-env';

type Props = {
	pageTitle: string;
	posts: ContentEntry<Post>[];
};
const { pageTitle, posts } = Astro.props;
---

<BaseLayout>
	<BaseHead slot="head" title={pageTitle} description={SITE_DESCRIPTION} />
	<header class="sr-only">
		<h1>{pageTitle}</h1>
	</header>
	<div aria-live="polite" id="blog-list" role="region">
		{
			posts.map((post) => {
				const { slug, title, publishedAt, terms } = post.data;
				const tags = terms?.tag;
				return (
					<article class="m-auto floating mb-6 p-6 transition-all duration-200 ease-in-out can-hover:hover:-translate-y-1 can-hover:hover:translate-x-1 can-hover:hover:shadow-lg motion-reduce:translate-x-0 motion-reduce:translate-y-0">
						<a rel="author" href={`/blog/${slug}/`}>
							<header class="max-w-prose mb-6">
								<h1
									aria-label="Blog Title"
									class="font-bold text-primary-900 text-2xl md:text-4xl leading-relaxed"
								>
									{`${title}`}
								</h1>
								<div class="text-sm text-gray-600">
									<span>Alex Moon on </span>
									<FormattedDate date={publishedAt!} />
								</div>
							</header>
						</a>

						<footer class="mt-6 text-sm text-gray-600">
							<Tags tags={tags ?? []} />
						</footer>
					</article>
				);
			})
		}
	</div>
</BaseLayout>
