{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "supports": [
        "drafts",
        "revisions",
        "search",
        "preview"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "unique": false
        },
        {
          "slug": "body",
          "label": "Content",
          "type": "portableText",
          "required": false,
          "unique": false
        }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "tag",
      "label": "Tags",
      "labelSingular": "Tag",
      "hierarchical": false,
      "collections": [
        "posts"
      ],
      "terms": [
        {
          "slug": "seeded",
          "label": "Seeded"
        }
      ]
    }
  ],
  "menus": [
    {
      "name": "primary",
      "label": "Primary Navigation",
      "items": [
        {
          "type": "custom",
          "label": "Home",
          "url": "/"
        },
        {
          "type": "custom",
          "label": "Blog",
          "url": "/blog"
        }
      ]
    }
  ],
  "content": {
    "posts": [
      {
        "id": "post-hello-world",
        "slug": "hello-world",
        "status": "published",
        "data": {
          "title": "Hello World",
          "body": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Welcome to the blog. This is your default seeded post."
                }
              ]
            }
          ]
        },
        "taxonomies": {
          "tag": [
            "seeded"
          ]
        }
      },
      {
        "id": "post-sorting-check",
        "slug": "sorting-check",
        "status": "published",
        "data": {
          "title": "Sorting Check",
          "body": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "This second seeded post exists to validate published-date ordering in blog and tag archives."
                }
              ]
            }
          ]
        },
        "taxonomies": {
          "tag": [
            "seeded"
          ]
        }
      }
    ]
  }
}
