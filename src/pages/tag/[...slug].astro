---
import { getEmDashCollection, getTerm } from 'emdash';
import ArchivePage from '../../components/ArchivePage.astro';

const { slug } = Astro.params;
const tagSlug = slug!;

const term = await getTerm('tag', tagSlug);

const { entries: filteredPosts } = await getEmDashCollection('posts', {
	status: 'published',
	where: { tag: tagSlug },
});

// Sort posts by date (newest first)
const posts = filteredPosts.toSorted(
	(a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const pageTitle = term?.label ?? tagSlug;
---

<ArchivePage {pageTitle} {posts} />
